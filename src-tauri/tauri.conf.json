{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyWallpaper",
  "identifier": "com.mywallpaper.desktop",
  "version": "1.0.257",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "https://dev.mywallpaper.online",
    "frontendDist": "https://dev.mywallpaper.online"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "MyWallpaper",
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "focus": true,
        "visible": true,
        "devtools": true,
        "additionalBrowserArgs": "--disable-features=CalculateNativeWinOcclusion --disable-backgrounding-occluded-windows --disable-renderer-backgrounding --disable-background-timer-throttling --enable-gpu-rasterization --enable-zero-copy --ignore-gpu-blocklist"
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "mywallpaper"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFENzEzNjg3Q0FCMkJCMDgKUldRSXU3TEtoelp4cmVibkJndzFGSDNGUTZMTFdTRGlhTFVJL0VJdHF4cmJ3dlRLbUY1ZXd4aTMK",
      "endpoints": [
        "https://github.com/MyWallpapers/client/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}